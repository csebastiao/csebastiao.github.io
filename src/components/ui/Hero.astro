---
import { Image } from 'astro:assets'

import SocialIcons from './SocialIcons.astro'


const {fullName, title, institute, profilePicture} = Astro.props
---
<div class='flex-1'>
  <h1 class='text-4xl font-bold mb-4'>
    Welcome! I'm <span class='text-secondary'>{fullName}</span>
  </h1>
  <p class='text-xl text-gray-600 mb-4'>{title}{institute ? ` at ${institute}` : ''}</p>
  <p class='text-lg mb-6'>
    I am a PhD Student in the <a href="https://nerds.itu.dk" class="hover:text-accent">NERDS</a> (NEtwoRks, Data, and Society) group at the IT University of Copenhagen, mainly supervised by <a href="http://michael.szell.net/" class="hover:text-accent">Michael Szell</a>. With a background in Physics and Complex Systems, I am working now in developing sustainable urban mobility infrastructures using Network and Data Science. My research is part of the <a href="https://www.just-streets.eu" class="hover:text-accent">Just Streets</a> Horizon Europe project.
  <p class='text-lg mb-6'>
    In my spare time, I am into literature 📖, and losing myself into rabbit holes on the Internet 🐇 
  </p>
  <div class='flex gap-4'>
    <SocialIcons />
  </div>
</div>
<div class='size-72 lg:block hidden'>
  <!-- Add your profile image -->
  <Image
    src={profilePicture}
    alt={fullName}
    class='w-full h-full mask mask-circle size-44'
  />
</div>
